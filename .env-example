# Model Configuration (OpenRouter Example)
model="openrouter:google/gemini-2.0-flash-lite-001"
api_key="your-openrouter-key"
base_url="https://openrouter.ai/api/v1"
temperature=0.3

# Backend Toggle
# Set to false to run without LangSmith Sandboxes
USE_SANDBOX=false

# LangSmith Tracing
LANGSMITH_API_KEY="your-langsmith-key"
LANGSMITH_TRACING=true
LANGSMITH_PROJECT="deep-agent-lab"
